{
  "expo": {
    "name": "SANAD",
    "slug": "sanad-app",
    "version": "1.0.0",
    "scheme": "sanad",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sanad.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan receipts.",
        "NSPhotoLibraryUsageDescription": "Used to attach receipt images.",
        "NSMicrophoneUsageDescription": "Used to record voice notes for transaction input."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FAFC"
      },
      "package": "com.sanad.app",
      "permissions": [
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "./plugins/withBudgetWidget",
      "./plugins/withAppIntents",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8B5CF6"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow SANAD to access your microphone for voice note input."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SANAD to access your photos for receipt scanning.",
          "cameraPermission": "Allow SANAD to access your camera for receipt scanning."
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
